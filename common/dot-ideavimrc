" .ideavimrc is a configuration file for IdeaVim plugin. It uses
"   the same commands as the original .vimrc configuration.
" You can find a list of commands here: https://jb.gg/h38q75
" Find more examples here: https://jb.gg/share-ideavimrc
"" -- Suggested options --
" Show a few lines of context around the cursor. Note that this makes the
" text scroll if you mouse-click near the start or end of the window.
set scrolloff=10
" easymotion 需要早于leader key设置
Plug 'easymotion/vim-easymotion'
set easymotion
let mapleader = " "
let maplocalleader = "\\"
" Do incremental searching.
set ignorecase
set smartcase
set incsearch
set hlsearch
set relativenumber
set notimeout
set showmode
set showcmd
set visualbell
"---------------plugin setting start------------------
set peekaboo
set which-key
let g:WhichKeyDesc_language_tools = "<leader>c code"
let g:WhichKey_FontSize = 16

Plug 'preservim/nerdtree'
Plug 'tpope/vim-surround'
Plug 'machakann/vim-highlightedyank'
Plug 'tpope/vim-commentary'
"---------------plugin setting end ------------------
" Don't use Ex mode, use Q for formatting.
map Q gq

" --- Enable IdeaVim plugins https://jb.gg/ideavim-plugins

" Core editing
nnoremap <leader><space> <Action>(GotoFile)
nnoremap <leader>/ <Action>(FindInPath)
inoremap jk <Esc>

" LSP-like navigation (prioritize Neovim habits)
nnoremap gd <Action>(GotoDeclaration)
nnoremap gD <Action>(GotoDeclaration)
nnoremap gI <Action>(GotoImplementation)
nnoremap gy <Action>(GotoTypeDeclaration)
nnoremap gr <Action>(FindUsages)
nnoremap gA <Action>(FindUsages)
nnoremap gi <Action>(JumpToLastChange)
nnoremap K <Action>(QuickJavaDoc)

" Diagnostics / signature / code actions
nnoremap gh <Action>(ShowErrorDescription)
nnoremap gk <Action>(ParameterInfo)
inoremap <C-k> <Action>(ParameterInfo)
nnoremap g. <Action>(ShowIntentionActions)
nnoremap <leader>ca <Action>(ShowIntentionActions)
nnoremap cd <Action>(RenameElement)
nnoremap <leader>cf <Action>(ReformatCode)
nnoremap <leader>cd <Action>(RenameElement)
nnoremap ]d <Action>(GotoNextError)
nnoremap [d <Action>(GotoPreviousError)
nnoremap g] <Action>(GotoNextError)
nnoremap g[ <Action>(GotoPreviousError)

" Structure navigation (Neovim-like in IDE)
nnoremap ]m <Action>(MethodDown)
nnoremap [m <Action>(MethodUp)
nnoremap ]M <Action>(MethodDown)
nnoremap [M <Action>(MethodUp)
nnoremap ]] <Action>(MethodDown)
nnoremap [[ <Action>(MethodUp)
nnoremap gs <Action>(FileStructurePopup)
nnoremap gS <Action>(GotoSymbol)

" Tabs, terminal, bookmarks, window
nnoremap ]b :tabnext<CR>
nnoremap [b :tabprevious<CR>
nnoremap <C-/> <Action>(ActivateTerminalToolWindow)
nnoremap <C-_> <Action>(ActivateTerminalToolWindow)
inoremap <C-/> <Action>(ActivateTerminalToolWindow)
inoremap <C-_> <Action>(ActivateTerminalToolWindow)
nnoremap <leader>mt <Action>(ToggleBookmark)
nnoremap <leader>ml <Action>(ActivateBookmarksToolWindow)
nnoremap qq <Action>(HideActiveWindow)
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l
nnoremap <A-h> <C-w>h
nnoremap <A-l> <C-w>l
nnoremap <A-k> <C-w>k
nnoremap <A-j> <C-w>j

" Plugin mapping
nnoremap <leader>e :NERDTreeToggle<CR>


"" -- Map IDE actions to IdeaVim -- https://jb.gg/abva4t
"" Map \r to the Reformat Code action
"map \r <Action>(ReformatCode)

"" Map <leader>d to start debug
"map <leader>d <Action>(Debug)

"" Map \b to toggle the breakpoint on the current line
"map \b <Action>(ToggleLineBreakpoint)